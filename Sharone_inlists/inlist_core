! inlist_core

&star_job


      show_log_description_at_start = .false.

      load_saved_model = .true.
      !load_model_filename = "planet_create_0.9685_MJ_2.0_RJ.mod"
      load_model_filename = "planet_create.mod"

      save_model_when_terminate = .true.
      !save_model_filename = "planet_core_1.0_MJ_10.0_ME_2.0_RJ.mod"
      save_model_filename = "planet_core.mod"
      required_termination_code_string = 'max_age'
      
      !set_initial_age = .true.
      !initial_age = 0.0 ! in years
      !set_initial_dt = .true.
      !years_for_initial_dt = 1.d-5 ! in years

      set_initial_model_number = .true.
      initial_model_number = 0
      
      change_initial_net = .true.      
      new_net_name = 'basic.net'

      ! controls for adding core of a certain density (alternatively, could fix radius)
      relax_core = .true.
      new_core_mass = 1.47e-04 ! 49 Mearth in Msun units
      core_avg_rho = 17.5d0 ! g/cm^3  !JJ comment: why is this density so high? A M_core = 10 M_earth planet should have a density of ~10 g/cm^3 if R ~ M^1/4
! Sharone Comment on density: Sorry this was bad code documentation on my part -> 17.5 is for a planet with a core mass of 49 M_earth
      core_avg_eps = 0.d0 ! ergs/g/sec
      dlg_core_mass_per_step = 0.05d0     ! decrease if convergence problems
      relax_core_years_for_dt = 0.1d0     ! increase(?) if convergence problems
      
      !pgstar_flag = .true.

/ !end of star_job


&eos
   eosDT_use_linear_interp_for_X = .true.
   use_other_eos_component = .true.
   use_other_eos_results = .true.
   eos_integer_ctrl(1) = 4 ! which tables to use
   eos_integer_ctrl(2) = 2 ! between-table interpolation method
   eos_integer_ctrl(3) = 2 ! in-table interpolation method
/ ! end of eos namelist


&kap
         Zbase = 0.02d0

      kap_file_prefix = 'gs98'
      kap_lowT_prefix = 'lowT_Freedman11'

/ ! end of kap namelist

&controls


         warning_limit_for_max_residual = 1d99 ! off until evolve
         warn_when_large_virial_thm_rel_err = 2d-2
         max_years_for_timestep = 1.0d7 ! Just added-sharone

      ! limit max_model_number as part of test_suite
         max_model_number = 520

        ! surface heating
        !column_depth_for_irradiation = 100.0
        !irradiation_flux = 1.d9     ! day side flux!!! Bill puts in 1/4 by hand

	! when to stop
	max_age = 2.d3

	! knobs
	!use_lnE_for_eps_grav = .false.
	T_mix_limit = 0
   
   use_gold2_tolerances = .false.
   use_gold_tolerances = .false.

	! output to files and terminal
	photo_interval = 50
	profile_interval = 100
	max_num_profile_models=1000
	history_interval = 2
	terminal_interval = 10
	write_header_frequency = 10

/


&pgstar
         
      ! top level controls

         !pause = .true. 
            ! if true, the code waits for user to enter a RETURN on the command line
      

/ ! end of pgstar namelist
