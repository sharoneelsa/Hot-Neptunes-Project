! inlist_strip

&star_job

      set_initial_age = .true.
      initial_age = 0
      set_initial_model_number = .true.
      initial_model_number = 0
      set_initial_dt = .true.
      years_for_initial_dt = 1.d-5 ! in years

      show_log_description_at_start = .false.
      
      load_saved_model = .true.
      load_model_filename = "planet_irradiate.mod"

      save_model_when_terminate = .true.
      save_model_filename = "planet_strip.mod"
      required_termination_code_string = 'max_age'
      
      relax_mass_scale = .true.
      new_mass = 2.06d-04 !!!
      
      change_initial_net = .true.      
      new_net_name = 'basic.net'

      set_initial_cumulative_energy_error = .true.
      new_cumulative_energy_error = 0d0
      
      !pgstar_flag = .true.
      
/ !end of star_job

&eos
   use_other_eos_component = .true.
   use_other_eos_results = .true.
   eos_integer_ctrl(1) = 4 ! which tables to use
   eos_integer_ctrl(2) = 2 ! between-table interpolation method
   eos_integer_ctrl(3) = 2 ! in-table interpolation method
   eosDT_use_linear_interp_for_X = .true.
/ ! end of eos namelist

&kap

      Zbase = 0.02d0

      kap_file_prefix = 'gs98'
      kap_lowT_prefix = 'lowT_Freedman11'

/ ! end of kap namelist

&controls

      !mesh_delta_coeff = 3.0d0
      !steps_before_use_gold2_tolerances = 3000
      warn_when_large_virial_thm_rel_err = 5d-2

      energy_eqn_option = 'dedt'
      use_gold2_tolerances = .true.

      ! limit max_model_number as part of test_suite
      max_model_number = 500 ! was original 900

      ! for create_initial_model
      initial_Z = 0.02d0
      initial_Y = 0.24d0

      ! when to stop
      max_age = 5d3

      ! knobs
      T_mix_limit = 0d0
      atm_option = 'fixed_Psurf'  ! JJ comment: Eventually want to comment out and do "default" atm option
      atm_fixed_Psurf = 1.0d6     ! JJ comment: Eventually want to comment out and do "default" atm option
      !atm_fixed_Psurf = 1.0d5 ! 0.1 bar
      !atm_fixed_Psurf = 2.0d4 ! 20mbar 0.02 bar
      !atm_fixed_Psurf = 2.5d5 ! 0.25 bar

      ! surface heating
      column_depth_for_irradiation = 300.d0 ! 3.d2 cm^2/g
      irradiation_flux = 1.22d8  ! 1.d8 erg/cm^2/s ! day side flux
      !irradiation_flux = 0
      
      ! Using MESA controls for irradiated atmosphere bdry condition
      !atm_option = 'irradiated_grey'
      !atm_irradiated_opacity = 'fixed'
      !atm_irradiated_T_eq = 814.9d0
      !atm_irradiated_kap_v = 6.0d-3          ! kap_v
      !atm_irradiated_kap_v_div_kap_th = 0.6d0  ! gamma
      !atm_irradiated_P_surf = 1.0d6
      
      ! modiefied surface boundary condition from atmosphere + inputs
      !use_other_surface_PT = .true.
      !x_ctrl(4) = 0.25d0                ! f
      !x_ctrl(5) = 0.6666666666666667d0  ! tau photosphere
      !x_ctrl(6) = 0.6d0                 ! gamma = kap_v/kap_th

      ! output to files and terminal
      photo_interval = 50
      profile_interval = 50
      max_num_profile_models=1000
      history_interval = 2
      terminal_interval = 10
      write_header_frequency = 10

      !report_solver_progress = .true. ! set true to see info about newton iterations
      report_ierr = .true. ! if true, produce terminal output when have some internal error

/

&pgstar
         
      ! top level controls
      
         !pause = .true. 
            ! if true, the code waits for user to enter a RETURN on the command line

/ ! end of pgstar namelist
